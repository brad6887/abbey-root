{
  "type": "object",
  "required": [
    "recommendation",
    "summary",
    "evidence",
    "recurring_work_eliminated",
    "estimated_effort",
    "estimated_frequency",
    "time_saving_score",
    "confidence",
    "alternatives",
    "assumptions"
  ],
  "properties": {
    "recommendation": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "document",
          "item"
        ],
        "properties": {
          "document": {
            "type": "string"
          },
          "item": {
            "type": "string"
          }
        }
      }
    },
    "recurring_work_eliminated": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "estimated_effort": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large"
      ]
    },
    "estimated_frequency": {
      "type": "string"
    },
    "time_saving_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item",
          "reason_not_selected"
        ],
        "properties": {
          "item": {
            "type": "string"
          },
          "reason_not_selected": {
            "type": "string"
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
