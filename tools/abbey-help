#!/bin/bash
#
# Abbey Root Tool: abbey-help
#
# Purpose:
#   Display available Abbey Root aliases and command-line tools.
#
# Usage:
#   abbey-help
#

# Colors
BLUE='\033[1;34m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE} Abbey Root Developer Toolkit${NC}"
echo -e "${BLUE}========================================${NC}"
echo

echo -e "${GREEN}Navigation${NC}"
echo "----------"
printf "  %-22s %s\n" "abbey" "Change to the Abbey Root repository"
printf "  %-22s %s\n" "ans" "Change to the Ansible directory"
echo

echo -e "${GREEN}Git${NC}"
echo "---"
printf "  %-22s %s\n" "abbey-git-status" "Show repository status"
printf "  %-22s %s\n" "abbey-git-history" "Show graphical Git history"
printf "  %-22s %s\n" "abbey-git-last" "Show the latest commit"
echo

echo -e "${GREEN}Automation${NC}"
echo "----------"
printf "  %-22s %s\n" "abbey-status" "Show Abbey Root lab status"
printf "  %-22s %s\n" "abbey-build" "Run the standard Abbey Root build pipeline"
printf "  %-22s %s\n" "abbey-validate" "Validate the Ansible inventory"
printf "  %-22s %s\n" "abbey-docs" "Generate documentation"
echo

echo -e "${GREEN}Help${NC}"
echo "----"
printf "  %-22s %s\n" "abbey-help" "Display this help screen"
echo

echo -e "${YELLOW}Typical Workflow${NC}"
echo "----------------"
echo

printf "  %-22s %s\n" "abbey"        "# Open the repository"
printf "  %-22s %s\n" "abbey-status" "# Check lab health"
printf "  %-22s %s\n" "abbey-build"  "# Validate and regenerate documentation"
printf "  %s\n" "git diff"
printf "  %s\n" "git add ."
printf "  %s\n" 'git commit -m "message"'
printf "  %s\n" "git push"

echo
echo "Tip: Most commands support '--help' for additional information."

