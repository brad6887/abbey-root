#!/bin/bash
#
# Abbey Root Tool: abbey-help
#
# Purpose:
#   Display available Abbey Root command-line tools from command headers.
#
# Usage:
#   abbey-help
#

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TOOLS_DIR="$REPO_ROOT/tools"

echo "========================================"
echo " Abbey Root Developer Toolkit"
echo "========================================"
echo
echo "Commands"
echo "--------"

for tool in "$TOOLS_DIR"/abbey-*; do
  [ -f "$tool" ] || continue
  [ -x "$tool" ] || continue

  command_name="$(basename "$tool")"

  purpose="$(
    awk '
      /^# Purpose:/ { in_purpose=1; next }
      /^# Usage:/ { in_purpose=0 }
      in_purpose && /^#/ {
        sub(/^# */, "")
        if (length($0) > 0) print
      }
    ' "$tool" | sed 's/^ *//' | paste -sd ' ' -
  )"

  printf "  %-22s %s\n" "$command_name" "$purpose"
done

cat <<EOF

Navigation Aliases
------------------
  abbey                  Change to the Abbey Root repository
  ans                    Change to the Ansible directory
  abbey-site             Change to the Astro site
  abbey-docdir           Change to the documentation directory

Typical Workflow
----------------
  abbey
  abbey-git-status
  abbey-build
  git add .
  git commit -m "message"
  git push

Tip: Command details are generated in docs/generated/abbey-commands.md
EOF
