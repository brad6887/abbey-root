#!/bin/bash
#
# Abbey Root Tool: abbey-help
#
# Purpose:
#   Display available Abbey Root aliases and command-line tools.
#
# Usage:
#   abbey-help
#

# Colors
BLUE='\033[1;34m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

cat <<EOF
========================================
 Abbey Root Developer Toolkit
========================================

Navigation
----------
  abbey                  Change to the Abbey Root repository
  ans                    Change to the Ansible directory
  abbey-site             Change to the Astro site
  abbey-docdir           Change to the documentation directory

Git
---
  abbey-git-status       Show repository status
  abbey-git-history      Show graphical Git history
  abbey-git-last         Show the latest commit

Development
-----------
  abbey-status           Show Abbey Root lab status
  abbey-build            Run the standard build pipeline
  abbey-docs             Generate project documentation
  abbey-validate         Validate inventory data

Ansible
--------
  abbey-ansible-site     Run the main site playbook
  abbey-ansible-update   Update all managed hosts
  abbey-ansible-facts    Collect host facts
  abbey-ansible-docker   Run the Docker playbook
  abbey-ansible-docs     Generate documentation playbook

Typical Workflow
----------------

  abbey
  abbey-git-status
  abbey-build
  git add .
  git commit -m "message"
  git push

Help
----
  abbey-help             Display this help screen

Tip: Most commands support '--help' for additional information.
EOF
