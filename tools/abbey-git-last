#!/bin/bash
#
# Abbey Root Tool: abbey-git-last
#
# Purpose:
#   Display the most recent Git commit for the Abbey Root repository.
#
# Usage:
#   abbey-git-last
#   abbey-git-last --help
#

set -e

# Colors
BLUE='\033[1;34m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
cat <<EOF
abbey-git-last

Display the most recent commit in the Abbey Root repository.

Usage:
    abbey-git-last

This command displays:

  • Commit hash
  • Author
  • Date
  • Commit message
  • Files changed

EOF
exit 0
fi

cd "$ABBEY_ROOT"

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE} Abbey Root - Last Git Commit${NC}"
echo -e "${BLUE}========================================${NC}"
echo

echo -e "${GREEN}Repository:${NC} $ABBEY_ROOT"
echo -e "${GREEN}Branch:${NC} $(git branch --show-current)"
echo -e "${GREEN}Date:${NC} $(date)"
echo

git show --stat --color=always HEAD
