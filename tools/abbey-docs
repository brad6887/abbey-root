#!/bin/bash
#
# Abbey Root Tool: abbey-docs
#
# Purpose:
#   Generate Abbey Root documentation.
#
# Usage:
#   abbey-docs
#   abbey-docs --help
#

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

BLUE='\033[1;34m'
GREEN='\033[1;32m'
NC='\033[0m'

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
cat <<EOF
abbey-docs

Generate Abbey Root documentation using Ansible.

Usage:
    abbey-docs

This command:

  • Runs the documentation playbook
  • Regenerates files in docs/generated/
  • Uses Ansible inventory and host_vars as source data

EOF
exit 0
fi

cd "$REPO_ROOT/ansible"

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE} Abbey Root Documentation Generation${NC}"
echo -e "${BLUE}========================================${NC}"
echo

echo -e "${GREEN}Repository:${NC} $REPO_ROOT"
echo -e "${GREEN}Playbook:${NC} playbooks/docs.yml"
echo -e "${GREEN}Date:${NC} $(date)"
echo

"$REPO_ROOT/tools/generate-command-docs.sh"
echo
ansible-playbook playbooks/docs.yml

echo
echo -e "${GREEN}✓ Documentation generation completed successfully.${NC}"
