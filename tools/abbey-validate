#!/bin/bash
#
# Abbey Root Tool: abbey-validate
#
# Purpose:
#   Validate the Abbey Root Ansible inventory.
#
# Usage:
#   abbey-validate
#   abbey-validate --help
# 
# This command:
#  - Validates required host variables
#  - Verifies inventory consistency
#  - Stops the workflow if validation fails

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Colors
BLUE='\033[1;34m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
cat <<EOF
abbey-validate

Validate the Abbey Root inventory before builds, deployments, or documentation generation.

Usage:
    abbey-validate

This command:

  • Validates required host variables
  • Verifies inventory consistency
  • Stops the build if validation fails

EOF
exit 0
fi

cd "$REPO_ROOT/ansible"

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE} Abbey Root Inventory Validation${NC}"
echo -e "${BLUE}========================================${NC}"
echo

echo -e "${GREEN}Repository:${NC} $REPO_ROOT"
echo -e "${GREEN}Playbook:${NC} playbooks/validate.yml"
echo -e "${GREEN}Date:${NC} $(date)"
echo

ansible-playbook playbooks/validate.yml

echo
echo -e "${GREEN}✓ Inventory validation completed successfully.${NC}"

