#!/usr/bin/env bash
# COMMAND: ai
# DESCRIPTION: Show Abbey AI helper information
set -euo pipefail

ABBEY_ROOT="${ABBEY_ROOT:-$HOME/git/abbey-root}"
source "$ABBEY_ROOT/tools/lib/config.sh"
load_abbey_config

KNOWLEDGE_FILE="$ABBEY_ROOT/$ABBEY_KNOWLEDGE_FILE"

usage() {
  cat <<HELP
Abbey AI

Usage:
  abbey ai                 Show Abbey AI connection/context info
  abbey ai context         Show current knowledge context
  abbey ai open            Print Open WebUI URL
  abbey ai check           Check Open WebUI connectivity
  abbey ai models          List available Open WebUI models
  abbey ai ask <prompt>    Ask Open WebUI a question
  abbey ai rebuild         Rebuild knowledge context
  abbey ai help            Show this help

Environment:
  OPEN_WEBUI_URL           Default: $OPEN_WEBUI_URL
HELP
}

ensure_knowledge() {
  if [[ ! -f "$KNOWLEDGE_FILE" ]]; then
    echo "Knowledge snapshot not found. Building it now..."
    "$ABBEY_ROOT/tools/bin/abbey-knowledge" build
    echo
  fi
}

case "${1:-info}" in
  info)
    ensure_knowledge

    echo "Abbey AI"
    echo
    echo "Open WebUI: $OPEN_WEBUI_URL"
    echo "Knowledge:  $KNOWLEDGE_FILE"
    echo
    echo "Suggested prompt to paste into Open WebUI:"
    echo
    cat <<'PROMPT'
You are Abbey AI, an assistant for the Abbey Root home Linux lab. Use the project knowledge below as context. Help with Linux, Docker, Ansible, Git, documentation, troubleshooting, and lab design. Prefer practical step-by-step guidance.
PROMPT
    echo
    echo "Attach or paste this file:"
    echo "$KNOWLEDGE_FILE"
    ;;

  context)
    ensure_knowledge
    cat "$KNOWLEDGE_FILE"
    ;;

  rebuild)
    "$ABBEY_ROOT/tools/bin/abbey-knowledge" build
    ;;

  open)
    echo "$OPEN_WEBUI_URL"
    ;;

  check)
    echo "Checking Open WebUI..."
    echo "URL: $OPEN_WEBUI_URL"
    echo

    if curl -fsS "$OPEN_WEBUI_URL/api/config" >/tmp/abbey-openwebui-config.json 2>/dev/null; then
      echo "OK   Open WebUI API reachable"
      if command -v python3 >/dev/null 2>&1; then
        python3 - <<'PYJSON'
import json
from pathlib import Path

data = json.loads(Path("/tmp/abbey-openwebui-config.json").read_text())
print(f"INFO Name: {data.get('name', 'unknown')}")
print(f"INFO Version: {data.get('version', 'unknown')}")
print(f"INFO Auth enabled: {data.get('features', {}).get('auth', 'unknown')}")
PYJSON
      fi
    else
      echo "WARN Open WebUI API not reachable"
      exit 1
    fi
    ;;

  models)
    if [[ -z "${OPEN_WEBUI_API_KEY:-}" ]]; then
      echo "Missing OPEN_WEBUI_API_KEY."
      echo "Add it to: $ABBEY_ROOT/.abbey/config.conf"
      exit 1
    fi

    curl -fsS "$OPEN_WEBUI_URL/api/models"       -H "Authorization: Bearer $OPEN_WEBUI_API_KEY"       > /tmp/abbey-openwebui-models.json

    python3 - <<'PYJSON'
import json
from pathlib import Path

data = json.loads(Path("/tmp/abbey-openwebui-models.json").read_text())
models = data.get("data", data if isinstance(data, list) else [])

print("Open WebUI Models")
print()

if not models:
    print("No models returned.")
else:
    for model in models:
        if isinstance(model, dict):
            model_id = model.get("id") or model.get("name") or "unknown"
            owned_by = model.get("owned_by")
            if owned_by:
                print(f"- {model_id} ({owned_by})")
            else:
                print(f"- {model_id}")
        else:
            print(f"- {model}")
PYJSON
    ;;

  ask)
    shift
    prompt="${*:-}"

    if [[ -z "$prompt" ]]; then
      echo "Usage: abbey ai ask <prompt>"
      exit 1
    fi

    if [[ -z "${OPEN_WEBUI_API_KEY:-}" ]]; then
      echo "Missing OPEN_WEBUI_API_KEY."
      echo "Add it to: $ABBEY_ROOT/.abbey/config.conf"
      exit 1
    fi

    python3 - "$OPEN_WEBUI_URL" "$OPEN_WEBUI_API_KEY" "$OPEN_WEBUI_MODEL" "$prompt" <<'PYJSON'
import json
import sys
import urllib.request
import urllib.error

url, api_key, model, prompt = sys.argv[1:5]

payload = {
    "model": model,
    "messages": [
        {
            "role": "system",
            "content": "You are Abbey AI, a practical assistant for the Abbey Root Linux lab. Keep answers concise and useful."
        },
        {
            "role": "user",
            "content": prompt
        }
    ]
}

request = urllib.request.Request(
    f"{url}/api/chat/completions",
    data=json.dumps(payload).encode("utf-8"),
    headers={
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json"
    },
    method="POST"
)

try:
    with urllib.request.urlopen(request, timeout=120) as response:
        data = json.loads(response.read().decode("utf-8"))
except urllib.error.HTTPError as exc:
    print(f"HTTP error: {exc.code}", file=sys.stderr)
    print(exc.read().decode("utf-8"), file=sys.stderr)
    sys.exit(1)
except Exception as exc:
    print(f"Request failed: {exc}", file=sys.stderr)
    sys.exit(1)

try:
    print(data["choices"][0]["message"]["content"].strip())
except Exception:
    print(json.dumps(data, indent=2))
PYJSON
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    echo "Unknown ai command: $1"
    echo
    usage
    exit 1
    ;;
esac
