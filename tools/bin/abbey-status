#!/usr/bin/env bash
# COMMAND: status
# DESCRIPTION: Show local Abbey Root status
set -euo pipefail

ABBEY_ROOT="${ABBEY_ROOT:-$HOME/git/abbey-root}"
STATUS_DIR="$ABBEY_ROOT/tools/status"

source "$STATUS_DIR/lib/output.sh"

echo "Abbey Root Status"
echo "Date: $(date)"
echo "Host: $(hostname)"
echo "Repo: $ABBEY_ROOT"

for check in "$STATUS_DIR"/checks/*.sh; do
  [[ -f "$check" ]] || continue
  source "$check"
done
