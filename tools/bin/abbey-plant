#!/usr/bin/env bash
#
# Abbey Root Tool: abbey-plant
#
# Purpose:
#   Manage, validate, and publish plant workspaces.
#
# Usage:
#   abbey plant validate <slug>
#   abbey plant publish <slug>
#

set -euo pipefail

REPO_DIR="${ABBEY_ROOT:-$HOME/git/abbey-root}"
PLANTS_DIR="$REPO_DIR/working/plants"
CONTENT_DIR="$REPO_DIR/content/plants"
PUBLIC_PLANTS_DIR="$REPO_DIR/site/public/images/plants"

ok_count=0
warn_count=0
fail_count=0

ok() {
    printf 'OK   %s\n' "$1"
    ((ok_count += 1))
}

warn() {
    printf 'WARN %s\n' "$1"
    ((warn_count += 1))
}

fail() {
    printf 'FAIL %s\n' "$1"
    ((fail_count += 1))
}

usage() {
    cat <<'USAGE'
Usage:
  abbey plant validate <slug>
  abbey plant publish <slug>

Commands:
  validate    Validate a plant workspace against the Plant Model
  publish     Generate Astro content and copy selected public images
USAGE
}

validate_plant() {
    local slug="${1:-}"

    if [[ -z "$slug" ]]; then
        echo "ERROR: Plant slug is required."
        echo
        usage
        exit 2
    fi

    local plant_dir="$PLANTS_DIR/$slug"
    local facts_file="$plant_dir/facts.yaml"

    echo "Plant Validation"
    echo "================"
    echo "Plant: $slug"
    echo

    echo "Directory"
    echo "---------"

    if [[ -d "$plant_dir" ]]; then
        ok "Plant directory exists: $plant_dir"
    else
        fail "Plant directory does not exist: $plant_dir"
        print_summary
        exit 1
    fi

    echo
    echo "Required Files"
    echo "--------------"

    local required_files=(
        "facts.yaml"
        "history.md"
        "story.md"
        "inventory.md"
        "photo-metadata.md"
    )

    local file
    for file in "${required_files[@]}"; do
        if [[ -f "$plant_dir/$file" ]]; then
            ok "$file"
        else
            fail "$file is missing"
        fi
    done

    echo
    echo "Required Directories"
    echo "--------------------"

    local required_dirs=(
        "photos"
        "sources"
    )

    local dir
    for dir in "${required_dirs[@]}"; do
        if [[ -d "$plant_dir/$dir" ]]; then
            ok "$dir/"
        else
            fail "$dir/ is missing"
        fi
    done

    echo
    echo "Facts"
    echo "-----"

    if [[ ! -f "$facts_file" ]]; then
        fail "Cannot validate facts because facts.yaml is missing"
        print_summary
        exit 1
    fi

    if ! python3 -c 'import yaml' >/dev/null 2>&1; then
        fail "Python module PyYAML is not installed"
        echo
        echo "Install it with:"
        echo "  python3 -m pip install --user pyyaml"
        print_summary
        exit 1
    fi

    local facts_output
    if ! facts_output="$(
        python3 - "$facts_file" "$plant_dir" <<'PY'
import sys
from pathlib import Path

import yaml

facts_path = Path(sys.argv[1])
plant_dir = Path(sys.argv[2])

try:
    with facts_path.open("r", encoding="utf-8") as handle:
        data = yaml.safe_load(handle)
except yaml.YAMLError as exc:
    print(f"FAIL|facts.yaml contains invalid YAML: {exc}")
    sys.exit(0)
except OSError as exc:
    print(f"FAIL|Unable to read facts.yaml: {exc}")
    sys.exit(0)

if not isinstance(data, dict):
    print("FAIL|facts.yaml must contain a YAML mapping")
    sys.exit(0)

print("OK|facts.yaml parses successfully")


def get_value(path):
    value = data
    for key in path.split("."):
        if not isinstance(value, dict) or key not in value:
            return None
        value = value[key]
    return value


required = (
    "name",
    "slug",
    "plant.type",
    "status.current",
)

for field in required:
    value = get_value(field)
    if value is None or value == "":
        print(f"FAIL|Required field is missing or empty: {field}")
    else:
        print(f"OK|{field}: {value}")

optional = (
    "plant.genus",
    "plant.species",
    "rescue.date",
    "status.updated",
)

for field in optional:
    value = get_value(field)
    if value is None or value == "":
        print(f"WARN|Optional field is not set: {field}")
    else:
        print(f"OK|{field}: {value}")

slug = get_value("slug")
if slug and slug != plant_dir.name:
    print(
        f"FAIL|facts.yaml slug '{slug}' does not match directory "
        f"name '{plant_dir.name}'"
    )
elif slug:
    print("OK|Slug matches plant directory")

for field in ("photos.hero", "photos.current"):
    value = get_value(field)

    if value is None or value == "":
        print(f"WARN|Photo reference is not set: {field}")
        continue

    path = plant_dir / value

    if path.is_file():
        print(f"OK|{field} exists: {value}")
    else:
        print(f"FAIL|{field} does not exist: {value}")
PY
    )"; then
        fail "Unable to execute facts.yaml validation"
    else
        while IFS='|' read -r level message; do
            case "$level" in
                OK)
                    ok "$message"
                    ;;
                WARN)
                    warn "$message"
                    ;;
                FAIL)
                    fail "$message"
                    ;;
            esac
        done <<< "$facts_output"
    fi

    print_summary

    if ((fail_count > 0)); then
        exit 1
    fi
}

publish_plant() {
    local slug="${1:-}"

    if [[ -z "$slug" ]]; then
        echo "ERROR: Plant slug is required."
        echo
        usage
        exit 2
    fi

    local plant_dir="$PLANTS_DIR/$slug"
    local facts_file="$plant_dir/facts.yaml"
    local output_file="$CONTENT_DIR/$slug.md"
    local public_dir="$PUBLIC_PLANTS_DIR/$slug"

    echo "Plant Publishing"
    echo "================"
    echo "Plant: $slug"
    echo

    validate_plant "$slug"

    echo
    echo "Publishing"
    echo "----------"

    mkdir -p "$CONTENT_DIR"
    rm -rf "$public_dir"
    mkdir -p "$public_dir"

    python3 - \
        "$facts_file" \
        "$plant_dir" \
        "$output_file" \
        "$public_dir" <<'PY'
import re
import shutil
import sys
from pathlib import Path

import yaml

facts_path = Path(sys.argv[1])
plant_dir = Path(sys.argv[2])
output_path = Path(sys.argv[3])
public_dir = Path(sys.argv[4])

with facts_path.open("r", encoding="utf-8") as handle:
    facts = yaml.safe_load(handle)


def get(path, default=None):
    value = facts
    for key in path.split("."):
        if not isinstance(value, dict):
            return default
        value = value.get(key)
        if value is None:
            return default
    return value


def read_document(relative_path):
    path = plant_dir / relative_path
    text = path.read_text(encoding="utf-8").strip()

    lines = text.splitlines()

    if lines and lines[0].startswith("# "):
        lines = lines[1:]

        while lines and not lines[0].strip():
            lines.pop(0)

    return "\n".join(lines).strip()


def copy_public_image(field_name, public_name):
    relative_path = get(field_name)

    if not relative_path:
        return None

    source = plant_dir / relative_path
    destination = public_dir / f"{public_name}{source.suffix.lower()}"

    shutil.copy2(source, destination)

    return f"/images/plants/{get('slug')}/{destination.name}"


def publish_history_photos(markdown, plant_name, slug):
    photos_dir = plant_dir / "photos"
    image_files = {
        photo.name: photo
        for photo in photos_dir.iterdir()
        if photo.is_file()
        and photo.suffix.lower() in {".jpg", ".jpeg", ".png", ".webp"}
    }

    published = {}
    output = []
    current_section = None

    photo_pattern = re.compile(
        r"^\s*(?:-\s+|####\s+)`?([^`]+\.(?:jpe?g|png|webp))`?\s*$",
        re.IGNORECASE,
    )

    for line in markdown.splitlines():
        if line.startswith("## "):
            current_section = line[3:].strip()

        match = photo_pattern.match(line)

        if not match:
            output.append(line)
            continue

        filename = match.group(1)
        source = image_files.get(filename)

        if source is None:
            output.append(line)
            continue

        if filename not in published:
            sequence = len(published) + 1
            destination = public_dir / (
                f"photo-{sequence:02d}{source.suffix.lower()}"
            )
            shutil.copy2(source, destination)
            published[filename] = (
                f"/images/plants/{slug}/{destination.name}"
            )

        alt_text = (
            f"{plant_name} — {current_section}"
            if current_section
            else f"{plant_name} progress photograph"
        )

        output.append(f"![{alt_text}]({published[filename]})")

    return "\n".join(output), published

name = get("name")
slug = get("slug")
plant_type = get("plant.type")
status = get("status.current")
genus = get("plant.genus")
species = get("plant.species")
acquired = get("rescue.date")
updated = get("status.updated")
tags = get("tags", [])

story_path = get("documents.story")
history_path = get("documents.history")

story = read_document(story_path)
history = read_document(history_path)

hero_image = copy_public_image("photos.hero", "hero")
current_image = copy_public_image("photos.current", "current")

history, history_images = publish_history_photos(
    history,
    name,
    slug,
)

species_label = genus
if species:
    species_label = f"{genus} {species}" if genus else species

description = (
    f"The rescue and recovery story of {name}, "
    f"a {species_label or plant_type} rescued from neglect."
)

frontmatter = {
    "title": name,
    "description": description,
    "type": plant_type,
    "status": status,
    "species": species_label,
    "acquired": acquired,
    "featured": True,
    "draft": False,
    "updatedDate": updated,
    "heroImage": hero_image,
    "currentImage": current_image,
    "tags": tags,
}

frontmatter = {
    key: value
    for key, value in frontmatter.items()
    if value is not None
}

body = f"""---
{yaml.safe_dump(frontmatter, sort_keys=False).strip()}
---

{story}

{history}
"""

output_path.write_text(body, encoding="utf-8")

print(f"Generated content: {output_path}")
if hero_image:
    print(f"Published hero image: {hero_image}")
if current_image:
    print(f"Published current image: {current_image}")
PY

    echo
    echo "PASS Plant published successfully."
}

print_summary() {
    echo
    echo "Result"
    echo "------"
    printf 'OK: %d  WARN: %d  FAIL: %d\n' \
        "$ok_count" "$warn_count" "$fail_count"

    if ((fail_count > 0)); then
        echo "FAIL Plant model validation failed."
    elif ((warn_count > 0)); then
        echo "PASS Plant model validation completed with warnings."
    else
        echo "PASS Plant model validation completed successfully."
    fi
}

command="${1:-help}"

case "$command" in
    validate)
        shift
        validate_plant "${1:-}"
        ;;
    publish)
        shift
        publish_plant "${1:-}"
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Unknown plant command: $command"
        echo
        usage
        exit 1
        ;;
esac
