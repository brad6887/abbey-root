#!/usr/bin/env bash
set -u

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
ABBEY_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
export ABBEY_ROOT

command="${1:-help}"

case "$command" in
  doctor)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-doctor" "$@"
    ;;

  journal)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-journal" "$@"
    ;;

  ai)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-ai" "$@"
    ;;

  status)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-status" "$@"
    ;;

  session)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-session" "$@"
    ;;

  end)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-end" "$@"
    ;;

  review)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-review" "$@"
    ;;

  next)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-next" "$@"
    ;;

  knowledge)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-knowledge" "$@"
    ;;

  site)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-site" "$@"
    ;;

  plant)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-plant" "$@"
    ;;

  lab)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-lab" "$@"
    ;;

  version)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-version" "$@"
    ;;

  context)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-context" "$@"
    ;;    

  help|-h|--help)
    "$ABBEY_ROOT/scripts/abbey_cli.py" help
    ;;

  *)
    echo "Unknown command: $command"
    echo
    echo "Run 'abbey help' for available commands."
    exit 1
    ;;
esac
