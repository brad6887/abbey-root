#!/usr/bin/env bash
set -u

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
ABBEY_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
export ABBEY_ROOT

command="${1:-help}"

case "$command" in
  doctor)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-doctor" "$@"
    ;;

  journal)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-journal" "$@"
    ;;

  ai)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-ai" "$@"
    ;;

  status)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-status" "$@"
    ;;

  knowledge)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-knowledge" "$@"
    ;;

  site)
    shift
    "$ABBEY_ROOT/tools/bin/abbey-site" "$@"
    ;;

  help|-h|--help)
    cat <<'HELP'
Abbey Root Toolkit

Usage:
  abbey doctor              Run Abbey Root health checks
  abbey journal <title>     Create or open a journal entry
  abbey ai                  Start Abbey AI helper
  abbey status              Show local Abbey Root status
  abbey knowledge build     Build a local knowledge snapshot
  abbey help                Show this help

Commands:
  doctor                    Run health checks
  journal                   Create or open a journal entry
  ai                        AI helper commands
  status                    Show local system/project status
  knowledge                 Build/view Abbey knowledge context
HELP
    ;;

  *)
    echo "Unknown command: $command"
    echo
    echo "Run 'abbey help' for available commands."
    exit 1
    ;;
esac
