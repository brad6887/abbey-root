#!/usr/bin/env bash
#
# Abbey Root Tool: abbey-journal
#
# Purpose:
#   Create or open an Abbey Root journal entry with valid Astro frontmatter.
#
# Usage:
#   abbey journal <journal title>
#
set -euo pipefail

REPO_DIR="${ABBEY_ROOT:-$HOME/git/abbey-root}"
JOURNAL_DIR="$REPO_DIR/content/journal"

DATE="$(date +%F)"
YEAR="$(date +%Y)"
TITLE="${*:-}"

if [[ -z "$TITLE" ]]; then
  echo "Usage: abbey journal <journal title>"
  echo "Example: abbey journal Completing the Journal Platform"
  exit 1
fi

SLUG="$(echo "$TITLE" \
  | tr '[:upper:]' '[:lower:]' \
  | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"

FILE="$JOURNAL_DIR/$YEAR/$DATE-$SLUG.md"

mkdir -p "$JOURNAL_DIR/$YEAR"

if [[ ! -f "$FILE" ]]; then
  cat > "$FILE" <<EOF
---
title: "$TITLE"
description: "TODO: Add a short summary."
date: $DATE
draft: false
tags:
  - Abbey Root
---

# $TITLE

## Summary

TODO

## Accomplishments

- TODO

## Lessons Learned

- TODO

## Next Steps

- TODO

EOF
fi

vi "$FILE"

echo
echo "Next step:"
echo "  abbey site build"
