#!/usr/bin/env bash
set -u

ABBEY_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
DOCTOR_DIR="$ABBEY_ROOT/tools/doctor"

source "$DOCTOR_DIR/lib/output.sh"

print_header "Abbey Root Doctor"

echo "Date: $(date)"
echo "Host: $(hostname)"
echo "Repo: $ABBEY_ROOT"
echo

for check in "$DOCTOR_DIR"/checks/*.sh; do
  [ -f "$check" ] || continue
  source "$check"
done

print_summary
