#!/usr/bin/env bash
#
# Abbey Root Tool: abbey-session
#
# Purpose:
#   Start Abbey work sessions and review completed session updates.
#
# Usage:
#   abbey session
#   abbey session context
#   abbey session update <slug>
#   abbey session review
#
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
ABBEY_ROOT="${ABBEY_ROOT:-$(cd "$SCRIPT_DIR/../.." && pwd)}"
export ABBEY_ROOT

ok() {
  echo "OK   $*"
}

warn() {
  echo "WARN $*"
}

info() {
  echo "INFO $*"
}

section() {
  echo
  echo "$1"
  echo "----------"
}

usage() {
  cat <<'HELP'
Abbey Session

Usage:
  abbey session            Show Abbey session startup information
  abbey session context [options]
                           Generate an upload-ready session context file
  abbey session update [options] <slug>
                           Create a new session update from the standard template
  abbey session review [file]
                           Review a selected session update, or the oldest unreviewed one
  abbey session help       Show this help

Context options:
  --stdout                 Write context to standard output
  --output FILE            Write context to a selected file

Update options:
  --title TITLE            Override the title derived from the slug
  -h, --help               Show update command help

The context command is read-only and failure-tolerant. Generated default files
are written under working/session-context/.

The review command runs Codex in a read-only sandbox. It recommends
documentation and planning changes but does not modify repository files.
HELP
}

latest_journal() {
  find "$ABBEY_ROOT/content/journal" \
    -type f \
    -name "*.md" \
    2>/dev/null |
    sort |
    tail -n 1
}

unreviewed_session_updates() {
  {
    grep -l '^reviewed:[[:space:]]*false[[:space:]]*$' \
      "$ABBEY_ROOT"/docs/session-updates/*.md \
      2>/dev/null || true
  } | sort
}

oldest_unreviewed_session() {
  unreviewed_session_updates | head -n 1
}

pending_session_updates() {
  local count

  count="$(unreviewed_session_updates | wc -l)"
  echo "${count//[[:space:]]/}"
}

session_start() {
  echo "========================================"
  echo " Abbey Root Session"
  echo "========================================"
  echo
  echo "Date: $(date)"
  echo "Host: $(hostname)"
  echo "Repo: $ABBEY_ROOT"

  section "Repository"

  if git -C "$ABBEY_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    ok "Git repository detected"
  else
    warn "Not a Git repository"
    exit 1
  fi

  local branch
  branch="$(git -C "$ABBEY_ROOT" branch --show-current 2>/dev/null || true)"

  if [[ -n "$branch" ]]; then
    ok "Current branch: $branch"
  else
    warn "Could not determine current branch"
  fi

  if [[ -z "$(git -C "$ABBEY_ROOT" status --porcelain)" ]]; then
    ok "Working tree clean"
  else
    warn "Working tree has uncommitted changes"
  fi

  if git -C "$ABBEY_ROOT" remote -v | grep -q .; then
    ok "Git remote configured"
  else
    warn "No Git remote configured"
  fi

  section "Planning"

  local project_status
  local next_file
  local session_update_count

  project_status="$ABBEY_ROOT/docs/planning/PROJECT_STATUS.md"
  next_file="$ABBEY_ROOT/docs/planning/NEXT.md"
  session_update_count="$(pending_session_updates)"

  if [[ -f "$project_status" ]]; then
    ok "Project status: docs/planning/PROJECT_STATUS.md"
  else
    warn "Missing PROJECT_STATUS.md"
  fi

  if [[ -f "$next_file" ]]; then
    ok "Next tasks: docs/planning/NEXT.md"
  else
    warn "Missing NEXT.md"
  fi

  if [[ "$session_update_count" -gt 0 ]]; then
    info "Unreviewed session updates: $session_update_count"
  else
    ok "Unreviewed session updates: none"
  fi

  section "Journal"

  local journal
  journal="$(latest_journal)"

  if [[ -n "$journal" ]]; then
    local relative_journal
    relative_journal="${journal#$ABBEY_ROOT/}"
    ok "Most recent journal: $relative_journal"
  else
    warn "No journal entries found"
  fi

  section "Workflow"

  echo "1. Review"
  echo "2. Define"
  echo "3. Build"
  echo "4. Validate"
  echo "5. Document"
  echo "6. Capture"
  echo "7. Commit"
  echo "8. Review"

  section "Current Step"

  echo "Review docs/planning/PROJECT_STATUS.md"
  echo "Review docs/planning/NEXT.md"
  echo "Choose one focused session objective"
  echo "Define what done looks like"

  echo
  echo "Tip: run 'abbey status' or 'abbey doctor' for deeper checks."
}


latest_session_update() {
  find "$ABBEY_ROOT/docs/session-updates" \
    -maxdepth 1 \
    -type f \
    -name "*.md" \
    2>/dev/null |
    sort |
    tail -n 1
}

context_section() {
  echo
  echo "## $1"
  echo
}

context_file() {
  local title="$1"
  local relative_file="$2"
  local absolute_file="$ABBEY_ROOT/$relative_file"

  context_section "$title"

  echo "Source: \`$relative_file\`"
  echo

  if [[ -f "$absolute_file" ]]; then
    cat "$absolute_file"
  else
    echo "_File not found._"
  fi
}

context_command() {
  local title="$1"
  shift

  context_section "$title"

  echo '```text'

  if "$@" 2>&1; then
    true
  else
    local command_status=$?
    echo
    echo "Command exit status: $command_status."
  fi

  echo '```'
}

session_context_document() {
  local generated
  local branch
  local commit
  local origin
  local recent_session
  local recent_journal

  generated="$(date --iso-8601=seconds)"
  branch="$(git -C "$ABBEY_ROOT" branch --show-current 2>/dev/null || true)"
  commit="$(git -C "$ABBEY_ROOT" log -1 --format='%H %s' 2>/dev/null || true)"
  origin="$(git -C "$ABBEY_ROOT" remote get-url origin 2>/dev/null || true)"
  recent_session="$(latest_session_update)"
  recent_journal="$(latest_journal)"

  cat <<EOF
# Abbey Root Session Context

> Generated session-start snapshot. This file is not an authoritative project
> document and should not be edited as a source of truth.

- Generated: $generated
- Host: $(hostname)
- Repository: $ABBEY_ROOT
- Branch: ${branch:-unknown}
- Commit: ${commit:-unknown}
- Origin: ${origin:-not configured}

## Intended Use

This file contains the repository context normally collected at the beginning
of an Abbey Root work session. Upload the file as the initial project context,
then define one focused objective and its definition of done.

EOF

  context_file "AI Session Guidance" \
    ".abbey/session-guidance.md"

  context_command "Repository Status" \
    git -C "$ABBEY_ROOT" status

  context_command "Changed Files" \
    git -C "$ABBEY_ROOT" diff --stat

  context_command "Recent Commits" \
    git -C "$ABBEY_ROOT" log --oneline -10

  context_file "Project Status" \
    "docs/planning/PROJECT_STATUS.md"

  context_file "Next" \
    "docs/planning/NEXT.md"

  context_file "Backlog" \
    "docs/planning/BACKLOG.md"

  context_file "Roadmap" \
    "docs/planning/ROADMAP.md"

  context_file "Ideas" \
    "docs/planning/IDEAS.md"

  context_section "Most Recent Session Update"

  if [[ -n "$recent_session" ]]; then
    local relative_session
    relative_session="${recent_session#$ABBEY_ROOT/}"
    echo "Source: \`$relative_session\`"
    echo
    cat "$recent_session"
  else
    echo "_No session update found._"
  fi

  context_section "Most Recent Journal Entry"

  if [[ -n "$recent_journal" ]]; then
    local relative_journal
    relative_journal="${recent_journal#$ABBEY_ROOT/}"
    echo "Source: \`$relative_journal\`"
    echo
    cat "$recent_journal"
  else
    echo "_No journal entry found._"
  fi

  context_command "Abbey Doctor" \
    "$ABBEY_ROOT/tools/bin/abbey-doctor"

  context_command "Abbey Version" \
    "$ABBEY_ROOT/tools/bin/abbey-version"
}

session_context() {
  local output_file=""
  local stdout=false
  local context_dir="$ABBEY_ROOT/working/session-context"
  local timestamp
  local temporary_file

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --stdout)
        stdout=true
        shift
        ;;

      --output)
        if [[ $# -lt 2 ]]; then
          echo "ERROR --output requires a file."
          return 1
        fi

        output_file="$2"
        shift 2
        ;;

      help|-h|--help)
        cat <<'HELP'
Abbey Session Context

Usage:
  abbey session context
  abbey session context --stdout
  abbey session context --output FILE

Generate a read-only, upload-ready Markdown snapshot containing repository,
planning, recent session, journal, and Abbey health context.

Default output:
  working/session-context/<timestamp>-abbey-root-context.md
HELP
        return 0
        ;;

      *)
        echo "ERROR Unknown session context option: $1"
        return 1
        ;;
    esac
  done

  if [[ "$stdout" == true && -n "$output_file" ]]; then
    echo "ERROR --stdout and --output cannot be used together."
    return 1
  fi

  if ! git -C "$ABBEY_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "ERROR Abbey Root is not a Git repository."
    return 1
  fi

  if [[ "$stdout" == true ]]; then
    session_context_document
    return 0
  fi

  if [[ -z "$output_file" ]]; then
    timestamp="$(date '+%Y-%m-%d-%H%M%S')"
    output_file="$context_dir/${timestamp}-abbey-root-context.md"
  elif [[ "$output_file" != /* ]]; then
    output_file="$PWD/$output_file"
  fi

  mkdir -p "$(dirname "$output_file")"

  temporary_file="$(mktemp)"
  trap 'rm -f "$temporary_file"' RETURN

  session_context_document > "$temporary_file"
  mv "$temporary_file" "$output_file"
  chmod 0644 "$output_file"

  echo "Session context written to:"
  echo "$output_file"
}


slug_title() {
  local slug="$1"

  python3 - "$slug" <<'PYTITLE'
import sys

slug = sys.argv[1]
words = slug.replace("_", "-").split("-")
minor_words = {"a", "an", "and", "as", "at", "by", "for", "in", "of", "on", "or", "the", "to"}

title_words = []

for index, word in enumerate(words):
    if not word:
        continue

    lower = word.lower()

    if index > 0 and lower in minor_words:
        title_words.append(lower)
    elif lower == "ai":
        title_words.append("AI")
    elif lower == "cli":
        title_words.append("CLI")
    else:
        title_words.append(lower.capitalize())

print(" ".join(title_words))
PYTITLE
}

validate_session_slug() {
  local slug="$1"

  if [[ ! "$slug" =~ ^[a-z0-9]+([a-z0-9-]*[a-z0-9])?$ ]]; then
    echo "ERROR Invalid session update slug: $slug"
    echo "Use lowercase letters, numbers, and single hyphens."
    return 1
  fi

  if [[ "$slug" == *--* ]]; then
    echo "ERROR Invalid session update slug: $slug"
    echo "Consecutive hyphens are not allowed."
    return 1
  fi
}

session_update_help() {
  cat <<'HELP'
Abbey Session Update

Usage:
  abbey session update [--title TITLE] <slug>

Create a new session update under:

  docs/session-updates/YYYY-MM-DD-<slug>.md

Options:
  --title TITLE            Override the title derived from the slug
  -h, --help               Show this help

Examples:
  abbey session update abbey-ai-decision-help
  abbey session update --title "Abbey AI Decision Help" abbey-ai-decision-help

The command refuses to overwrite an existing file.
HELP
}

session_update() {
  local slug=""
  local title=""
  local date_value
  local update_dir
  local update_file
  local relative_file
  local temporary_file

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)
        if [[ $# -lt 2 || -z "$2" ]]; then
          echo "ERROR --title requires a value."
          return 1
        fi

        title="$2"
        shift 2
        ;;

      help|-h|--help)
        session_update_help
        return 0
        ;;

      -*)
        echo "ERROR Unknown session update option: $1"
        return 1
        ;;

      *)
        if [[ -n "$slug" ]]; then
          echo "ERROR Only one session update slug may be supplied."
          return 1
        fi

        slug="$1"
        shift
        ;;
    esac
  done

  if [[ -z "$slug" ]]; then
    session_update_help
    return 1
  fi

  validate_session_slug "$slug" || return 1

  if [[ -z "$title" ]]; then
    title="$(slug_title "$slug")"
  fi

  date_value="$(date '+%Y-%m-%d')"
  update_dir="$ABBEY_ROOT/docs/session-updates"
  update_file="$update_dir/${date_value}-${slug}.md"
  relative_file="${update_file#$ABBEY_ROOT/}"

  if [[ -e "$update_file" ]]; then
    echo "ERROR Session update already exists:"
    echo "$relative_file"
    return 1
  fi

  mkdir -p "$update_dir"

  temporary_file="$(mktemp)"
  trap 'rm -f "$temporary_file"' RETURN

  cat > "$temporary_file" <<EOF
---
title: "$title"
description: "TODO: Add a concise description of this session."
date: $date_value
status: pending
reviewed: false
session: primary
tags:
  - Abbey Root
---

# $title

## Objective

TODO

## Definition of Done

- TODO

## Summary

TODO

## Accomplishments

- TODO

## Impact

TODO

## Validation

- TODO

## Lessons Learned

TODO

## Next Steps

- TODO

## Notes

TODO
EOF

  mv "$temporary_file" "$update_file"
  chmod 0644 "$update_file"

  echo "Session update created:"
  echo "$relative_file"
  echo
  echo "Next:"
  echo "  Edit the session update, then run 'abbey review'."
}


session_review() {
  local requested_session="${1:-}"
  local session_file
  local relative_session

  if ! command -v codex >/dev/null 2>&1; then
    echo "ERROR Codex CLI is not available."
    exit 1
  fi

  if [[ -n "$requested_session" ]]; then
    if [[ "$requested_session" = /* ]]; then
      session_file="$requested_session"
    else
      session_file="$ABBEY_ROOT/$requested_session"
    fi

    if [[ ! -f "$session_file" ]]; then
      echo "ERROR Session update not found: $requested_session"
      exit 1
    fi
  else
    session_file="$(oldest_unreviewed_session)"
  fi

  echo "========================================"
  echo " Abbey Session Review"
  echo "========================================"
  echo

  if [[ -z "$session_file" ]]; then
    ok "No unreviewed session updates found."
    return 0
  fi

  relative_session="${session_file#$ABBEY_ROOT/}"

  echo "Session: $relative_session"
  echo "Mode:    read-only"
  echo

  {
    cat <<EOF_PROMPT
Perform a read-only Abbey Root session reconciliation review using only the
repository content supplied below.

Do not attempt to run shell commands, browse the web, use connectors, or inspect
files that are not included in this prompt.

Review this session update:

$relative_session

Compare it against the supplied authoritative planning documents.

Produce a concise operational report using exactly these sections:

Result
------

State exactly one of:

- READY
- NOT READY

Use READY only when no required session-related reconciliation remains.
If required edits or required verification remain, use NOT READY.

Required Reconciliation
-----------------------

List only changes required before the session can be marked reviewed.

Group required changes by file. State each required action once. Do not repeat
the same finding in later sections.

Do not include optional improvements or incidental repository cleanup here.

Verification Required
---------------------

List only questions that must be resolved before reconciliation can be
completed.

Do not treat missing detail in a summary or command list as proof that an action
did not occur. Treat such cases as verification rather than prescribing a
change.

If no verification is required, write:

None.

Suggested Follow-Up
-------------------

List useful session-related follow-up work that is not required to mark the
session reviewed.

Clearly label inferred or optional recommendations as suggestions. Do not treat
model-inferred work as accepted project work.

If no follow-up is warranted, write:

None.

No Session-Related Changes
--------------------------

List all supplied authoritative files that require no session-related change on
one concise line.

Each supplied authoritative file must appear exactly once, either under
Required Reconciliation or under No Session-Related Changes.

Incidental Drift
----------------

List unrelated repository drift briefly. Incidental drift must never affect the
Result.

If no incidental drift is found, write:

None.

Additional rules:

- Recommend the smallest authoritative changes necessary.
- Planning documents summarize sessions rather than reproducing them.
- PROJECT_STATUS.md should summarize durable completed capabilities. Do not
  require it to also describe unfinished rollout details when those details
  belong in BACKLOG.md.
- Prefer concise additions over implementation detail already preserved in the
  session update.
- Preserve the distinction between speculative ideas and accepted work.
- Recommend BACKLOG.md only when the selected session clearly establishes the
  work as accepted, intended, or required.
- Recommend NEXT.md only when current project context independently establishes
  immediate priority.
- Distinguish one completed implementation from a broader unfinished capability.
- Do not recommend metadata changes unless the supplied evidence establishes the
  expected value.
- Treat reviewed: true as meaning completed outcomes and accepted unfinished
  work have been reconciled. Optional enhancements do not have to be completed.
- Never recommend changing status unless PLANNING_SCHEMA.md explicitly defines
  the required status value for this session state. When it does not, leave
  status unchanged and do not make it a verification requirement.
- Do not require verification of every historical Next Step. Require
  verification only when resolving it is necessary to decide a specific
  authoritative planning edit.
- Suggested Follow-Up must come directly from unfinished work or explicit ideas
  in the selected session. Do not invent new implementation approaches,
  automation opportunities, or architectural enhancements.
- Return recommendations only. Do not apply changes.

Repository evidence follows.

============================================================
SESSION UPDATE: $relative_session
============================================================

EOF_PROMPT

    cat "$session_file"

    for planning_file in \
      docs/planning/PROJECT_STATUS.md \
      docs/planning/NEXT.md \
      docs/planning/BACKLOG.md \
      docs/planning/ROADMAP.md \
      docs/planning/IDEAS.md \
      docs/reference/PLANNING_SCHEMA.md
    do
      echo
      echo "============================================================"
      echo "AUTHORITATIVE FILE: $planning_file"
      echo "============================================================"
      echo

      if [[ -f "$ABBEY_ROOT/$planning_file" ]]; then
        cat "$ABBEY_ROOT/$planning_file"
      else
        echo "FILE NOT FOUND"
      fi
    done
  } |
    codex exec \
      --sandbox read-only \
      --cd "$ABBEY_ROOT" \
      --ephemeral \
      --output-last-message /tmp/abbey-session-review.txt \
      - >/tmp/abbey-session-review.log 2>&1 || {
        cat /tmp/abbey-session-review.log >&2
        return 1
      }

  cat /tmp/abbey-session-review.txt
}

command="${1:-start}"

case "$command" in
  start)
    session_start
    ;;

  context)
    shift
    session_context "$@"
    ;;

  update)
    shift
    session_update "$@"
    ;;

  review)
    shift
    session_review "$@"
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    echo "Unknown session command: $command"
    echo
    usage
    exit 1
    ;;
esac
