#!/usr/bin/env bash
# COMMAND: knowledge
# DESCRIPTION: Build or show Abbey AI knowledge context
set -euo pipefail

ABBEY_ROOT="${ABBEY_ROOT:-$HOME/git/abbey-root}"
source "$ABBEY_ROOT/tools/lib/config.sh"
load_abbey_config

SNAPSHOT="$ABBEY_ROOT/$ABBEY_KNOWLEDGE_FILE"
KNOWLEDGE_DIR="$(dirname "$SNAPSHOT")"

usage() {
  cat <<'HELP'
Abbey Knowledge

Usage:
  abbey knowledge build     Build a local Abbey Root knowledge snapshot
  abbey knowledge show      Show the current knowledge snapshot path
HELP
}

list_files() {
  local title="$1"
  local path="$2"
  local pattern="${3:-*}"

  echo "## $title"
  echo

  if [[ -d "$ABBEY_ROOT/$path" ]]; then
    find "$ABBEY_ROOT/$path" -maxdepth 3 -type f -name "$pattern" \
      | sed "s#$ABBEY_ROOT/##" \
      | sort \
      | sed 's/^/- /'
  else
    echo "- Not found: $path"
  fi

  echo
}

section_excerpt() {
  local title="$1"
  local file="$2"
  local lines="${3:-80}"

  echo "## $title"
  echo

  if [[ -f "$ABBEY_ROOT/$file" ]]; then
    echo "Source: $file"
    echo
    sed -n "1,${lines}p" "$ABBEY_ROOT/$file"
  else
    echo "- Not found: $file"
  fi

  echo
}

build_snapshot() {
  mkdir -p "$KNOWLEDGE_DIR"

  {
    echo "# Abbey Root Knowledge Snapshot"
    echo
    echo "- Generated: $(date)"
    echo "- Host: $(hostname)"
    echo "- Repository: $ABBEY_ROOT"
    echo

    echo "## Git"
    echo
    if [[ -d "$ABBEY_ROOT/.git" ]]; then
      cd "$ABBEY_ROOT"
      echo "- Branch: $(git branch --show-current 2>/dev/null || echo unknown)"
      echo "- Origin: $(git remote get-url origin 2>/dev/null || echo none)"
      echo "- Working tree: $(git status --porcelain | wc -l | awk '{print $1}') changed files"
      echo
      echo "### Recent Commits"
      echo
      git log --oneline -8 2>/dev/null | sed 's/^/- /' || true
    else
      echo "- Git repository not found"
    fi
    echo

    echo "## Docker Containers"
    echo
    if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
      docker ps --format '- {{.Names}}: {{.Status}}'
    else
      echo "- Docker unavailable"
    fi
    echo

    echo "## Inventory"
    echo
    if [[ -f "$ABBEY_ROOT/ansible/inventory/hosts.yml" ]]; then
      sed -n '1,160p' "$ABBEY_ROOT/ansible/inventory/hosts.yml"
    else
      echo "- Inventory not found"
    fi
    echo

    list_files "Playbooks" "ansible/playbooks" "*.yml"
    list_files "Roles" "ansible/roles"
    list_files "Tools" "tools/bin"
    list_files "Planning Documents" "docs/planning" "*.md"
    list_files "Generated Documentation" "docs/generated" "*.md"
    list_files "Runbooks" "docs/runbooks" "*.md"
    list_files "Guides" "docs/guides" "*.md"
    list_files "Content Journal Entries" "content/journal" "*.md"

    section_excerpt "Current Project Status" "docs/planning/PROJECT_STATUS.md" 120
    section_excerpt "Next Actions" "docs/planning/NEXT.md" 120
    section_excerpt "Roadmap" "docs/planning/ROADMAP.md" 120
    section_excerpt "Backlog" "docs/planning/BACKLOG.md" 120
    section_excerpt "Abbey CLI Guide" "docs/guides/abbey-cli.md" 160
  } > "$SNAPSHOT"

  echo "Knowledge snapshot written to:"
  echo "$SNAPSHOT"
}

case "${1:-help}" in
  build)
    build_snapshot
    ;;
  show)
    echo "$SNAPSHOT"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown knowledge command: $1"
    echo
    usage
    exit 1
    ;;
esac
