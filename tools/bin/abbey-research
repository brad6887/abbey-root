#!/usr/bin/env bash
#
# Abbey Root Tool: abbey-research
#
# Purpose:
#   Run structured research prompts through a configured Ollama model
#   and preserve the raw model response in a file.
#
set -euo pipefail

ABBEY_ROOT="${ABBEY_ROOT:-$HOME/git/abbey-root}"

source "$ABBEY_ROOT/tools/lib/config.sh"
load_abbey_config

usage() {
  cat <<'HELP'
Abbey Research

Usage:
  abbey research run \
    --model MODEL \
    --prompt FILE \
    [--input FILE ...] \
    --output FILE \
    [--max-tokens N] \
    [--force]

  abbey research normalize \
    --type TYPE \
    --model MODEL \
    --input FILE \
    --output FILE \
    [--force]

  abbey research sanitize \
    --input FILE \
    --output FILE

  abbey research validate \
    --input FILE

  abbey research validate-review \
    --manifest FILE \
    --corpus FILE

  abbey research validate-discovery \
    --manifest FILE \
    --corpus FILE \
    --batch FILE

  abbey research discover \
    --model MODEL \
    --prompt FILE \
    --corpus FILE \
    --batch-manifest FILE \
    --output-dir DIR \
    [--max-tokens N] \
    [--resume] \
    [--validate-only]

  abbey research fact-lock propose \
    --model MODEL \
    --suite FILE \
    --output FILE \
    [--max-tokens N] \
    [--force]

  abbey research fact-lock validate \
    --suite FILE \
    --proposal FILE \
    [--normalized-output FILE]

  abbey research fact-lock review \
    --suite FILE \
    --proposal FILE

  abbey research fact-lock review-init \
    --suite FILE \
    --proposal FILE \
    --output FILE

  abbey research status

Options:
  --type TYPE     Research artifact type (default: generic)
  --model MODEL   Ollama model to use
  --prompt FILE   Research prompt file
  --input FILE    Input document supplied to the command
  --output FILE   File that receives the result
  --max-tokens N  Maximum generated tokens (default: 6144)
  --force         Replace an existing output file
  -h, --help      Show this help

Canonical normalized structure:

  # Research Result
  ## Summary
  ## Observations
  ## Evidence
  ## Conclusions
  ## Limitations
  ## Open Questions

Examples:
  abbey research run \
    --model gpt-oss:20b \
    --prompt working/research/PROMPT.md \
    --input working/research/facebook-posts.md \
    --output working/research/results/gpt-oss-20b.md

  abbey research normalize \
    --model gpt-oss:20b \
    --input working/research/results/gpt-oss-20b.md \
    --output working/research/normalized/gpt-oss-20b.md

  abbey research validate \
    --input working/research/normalized/gpt-oss-20b.md

  abbey research validate-review \
    --manifest working/research/voice-analysis/review.json \
    --corpus /path/to/clean_corpus.csv

  abbey research validate-discovery \
    --manifest working/research/voice-analysis/discovery.json \
    --corpus /path/to/clean_corpus.csv \
    --batch working/research/voice-analysis/batch-001.md

  abbey research discover \
    --model gpt-oss:20b \
    --prompt docs/research/voice-analysis/prompts/full-corpus-observation-discovery.md \
    --corpus /path/to/clean_corpus.csv \
    --batch-manifest working/research/voice-analysis/batches/manifest.json \
    --output-dir working/research/voice-analysis/discovery-run \
    --max-tokens 10000 \
    --resume

  abbey research fact-lock propose \
    --model gpt-oss:20b \
    --suite working/research/voice-analysis/request-suite.json \
    --output working/research/voice-analysis/fact-lock-proposal.json \
    --max-tokens 16000

  abbey research fact-lock validate \
    --suite working/research/voice-analysis/request-suite.json \
    --proposal working/research/voice-analysis/fact-lock-proposal.json \
    --normalized-output working/research/voice-analysis/fact-lock-proposal-normalized.json

  abbey research fact-lock review \
    --suite working/research/voice-analysis/request-suite.json \
    --proposal working/research/voice-analysis/fact-lock-proposal-normalized.json

  abbey research fact-lock review-init \
    --suite working/research/voice-analysis/request-suite.json \
    --proposal working/research/voice-analysis/fact-lock-proposal-normalized.json \
    --output working/research/voice-analysis/fact-lock-review.json

  abbey research status
HELP
}

run_research() {
  local model=""
  local prompt_file=""
  local output_file=""
  local max_tokens="6144"
  local force="false"
  local -a input_files=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)
        if [[ -z "${2:-}" ]]; then
          echo "Option --type requires an artifact type." >&2
          exit 1
        fi

        artifact_type="$2"
        shift 2
        ;;

      --model)
        if [[ -z "${2:-}" ]]; then
          echo "Option --model requires a model name." >&2
          exit 1
        fi

        model="$2"
        shift 2
        ;;

      --prompt)
        if [[ -z "${2:-}" ]]; then
          echo "Option --prompt requires a file." >&2
          exit 1
        fi

        prompt_file="$2"
        shift 2
        ;;

      --input)
        if [[ -z "${2:-}" ]]; then
          echo "Option --input requires a file." >&2
          exit 1
        fi

        input_files+=("$2")
        shift 2
        ;;

      --output)
        if [[ -z "${2:-}" ]]; then
          echo "Option --output requires a file." >&2
          exit 1
        fi

        output_file="$2"
        shift 2
        ;;

      --max-tokens)
        if [[ ! "${2:-}" =~ ^[1-9][0-9]*$ ]]; then
          echo "Option --max-tokens requires a positive integer." >&2
          exit 1
        fi
        max_tokens="$2"
        shift 2
        ;;

      --force)
        force="true"
        shift
        ;;

      -h|--help|help)
        usage
        exit 0
        ;;

      *)
        echo "Unknown option: $1" >&2
        echo >&2
        usage >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$model" ]]; then
    echo "Missing required option: --model" >&2
    exit 1
  fi

  if [[ -z "$prompt_file" ]]; then
    echo "Missing required option: --prompt" >&2
    exit 1
  fi

  if [[ -z "$output_file" ]]; then
    echo "Missing required option: --output" >&2
    exit 1
  fi

  if [[ ! -f "$prompt_file" ]]; then
    echo "Prompt file not found:" >&2
    echo "$prompt_file" >&2
    exit 1
  fi

  local input_file

  for input_file in "${input_files[@]}"; do
    if [[ ! -f "$input_file" ]]; then
      echo "Input file not found:" >&2
      echo "$input_file" >&2
      exit 1
    fi
  done

  if [[ -e "$output_file" && "$force" != "true" ]]; then
    echo "Output file already exists:" >&2
    echo "$output_file" >&2
    echo >&2
    echo "Use --force to replace it." >&2
    exit 1
  fi

  mkdir -p "$(dirname "$output_file")"

  python3 - \
    "$OLLAMA_URL" \
    "$model" \
    "$prompt_file" \
    "$output_file" \
    "$max_tokens" \
    "${input_files[@]}" <<'PYTHON'
import json
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

ollama_url = sys.argv[1]
model = sys.argv[2]
prompt_path = Path(sys.argv[3])
output_path = Path(sys.argv[4])
max_tokens = int(sys.argv[5])
input_paths = [Path(value) for value in sys.argv[6:]]

prompt = prompt_path.read_text(encoding="utf-8")

input_sections = []

for input_path in input_paths:
    input_sections.append(
        f"===== INPUT: {input_path} =====\n"
        f"{input_path.read_text(encoding='utf-8')}"
    )

user_content = prompt

if input_sections:
    user_content += (
        "\n\n"
        "Research inputs:\n\n"
        + "\n\n".join(input_sections)
    )

payload = {
    "model": model,
    "stream": False,
    "think": False,
    "options": {
        "num_ctx": max(16384, max_tokens * 2),
        "num_predict": max_tokens,
    },
    "messages": [
        {
            "role": "system",
            "content": (
                "You are participating in a structured Abbey Root "
                "research workflow. Use only the supplied research "
                "prompt and input documents. Preserve traceability "
                "between findings and evidence. Return the requested "
                "research artifacts as Markdown."
            ),
        },
        {
            "role": "user",
            "content": user_content,
        },
    ],
}

print("Abbey Research")
print()
print(f"Model:   {model}")
print(f"Ollama:  {ollama_url}")
print(f"Prompt:  {prompt_path}")
print(f"Inputs:  {len(input_paths)}")
print(f"Output:  {output_path}")
print()
print("Running research...")

request = urllib.request.Request(
    f"{ollama_url.rstrip('/')}/api/chat",
    data=json.dumps(payload).encode("utf-8"),
    headers={"Content-Type": "application/json"},
    method="POST",
)

started = time.monotonic()

try:
    with urllib.request.urlopen(request, timeout=1200) as response:
        response_data = json.loads(
            response.read().decode("utf-8")
        )
except urllib.error.HTTPError as exc:
    print(f"HTTP error: {exc.code}", file=sys.stderr)
    print(exc.read().decode("utf-8"), file=sys.stderr)
    sys.exit(1)
except Exception as exc:
    print(f"Ollama request failed: {exc}", file=sys.stderr)
    sys.exit(1)

runtime = time.monotonic() - started
content = response_data.get("message", {}).get("content", "")

thinking = response_data.get("message", {}).get(
    "thinking",
    "",
)

if not content.strip():
    print("Ollama returned an empty response.", file=sys.stderr)
    print(
        "Done reason: "
        f"{response_data.get('done_reason', 'unknown')}",
        file=sys.stderr,
    )
    print(
        "Prompt tokens: "
        f"{response_data.get('prompt_eval_count', 'unknown')}",
        file=sys.stderr,
    )
    print(
        "Generated tokens: "
        f"{response_data.get('eval_count', 'unknown')}",
        file=sys.stderr,
    )
    print(
        f"Thinking characters: {len(thinking)}",
        file=sys.stderr,
    )
    sys.exit(1)

output_path.write_text(
    content.rstrip() + "\n",
    encoding="utf-8",
)

print()
print("Research complete.")
print(f"Runtime: {runtime:.1f} seconds")
print(
    "Prompt tokens: "
    f"{response_data.get('prompt_eval_count', 'unknown')}"
)
print(
    "Output tokens: "
    f"{response_data.get('eval_count', 'unknown')}"
)
print(f"Result: {output_path}")
PYTHON
}


normalize_research() {
  local model=""
  local input_file=""
  local output_file=""
  local force="false"
  local artifact_type="generic"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)
        if [[ -z "${2:-}" ]]; then
          echo "Option --type requires an artifact type." >&2
          exit 1
        fi

        artifact_type="$2"
        shift 2
        ;;
      --model)
        if [[ -z "${2:-}" ]]; then
          echo "Option --model requires a model name." >&2
          exit 1
        fi

        model="$2"
        shift 2
        ;;

      --input)
        if [[ -z "${2:-}" ]]; then
          echo "Option --input requires a file." >&2
          exit 1
        fi

        input_file="$2"
        shift 2
        ;;

      --output)
        if [[ -z "${2:-}" ]]; then
          echo "Option --output requires a file." >&2
          exit 1
        fi

        output_file="$2"
        shift 2
        ;;

      --force)
        force="true"
        shift
        ;;

      -h|--help|help)
        usage
        exit 0
        ;;

      *)
        echo "Unknown option: $1" >&2
        echo >&2
        usage >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$model" ]]; then
    echo "Missing required option: --model" >&2
    exit 1
  fi

  if [[ -z "$input_file" ]]; then
    echo "Missing required option: --input" >&2
    exit 1
  fi

  if [[ -z "$output_file" ]]; then
    echo "Missing required option: --output" >&2
    exit 1
  fi

  if [[ ! -f "$input_file" ]]; then
    echo "Input file not found:" >&2
    echo "$input_file" >&2
    exit 1
  fi

  case "$artifact_type" in
    generic|observation)
      ;;
    *)
      echo "Unsupported artifact type: $artifact_type" >&2
      echo "Supported types: generic observation" >&2
      exit 1
      ;;
  esac

  if [[ -e "$output_file" && "$force" != "true" ]]; then
    echo "Output file already exists:" >&2
    echo "$output_file" >&2
    echo >&2
    echo "Use --force to replace it." >&2
    exit 1
  fi

  mkdir -p "$(dirname "$output_file")"

  python3 - \
    "$OLLAMA_URL" \
    "$model" \
    "$artifact_type" \
    "$input_file" \
    "$output_file" <<'PYTHON_NORMALIZE'
import json
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

ollama_url = sys.argv[1]
model = sys.argv[2]
artifact_type = sys.argv[3]
input_path = Path(sys.argv[4])
output_path = Path(sys.argv[5])

raw_content = input_path.read_text(encoding="utf-8")

if artifact_type == "observation":
    structure = """
# Observation

## Question

## Corpus

## Method

## Findings

## Interpretation

## Questions Raised

## Status
"""
else:
    structure = """
# Research Result

## Summary

## Observations

## Evidence

## Conclusions

## Limitations

## Open Questions
"""

instructions = f"""Normalize the supplied raw research artifact.

Return Markdown using exactly this structure and heading order:

{structure}

Requirements:

- Preserve the meaning of the raw artifact.
- Use only information present in the raw artifact.
- This is a normalization pass, not a summarization pass.
- Preserve all factual detail from the raw artifact.
- Do not shorten findings, remove examples, or collapse evidence.
- Source identifiers such as FB-000000 are mandatory evidence references and must be retained.
- Do not invent findings or evidence.
- Keep observations separate from conclusions.
- Normalization is a structural transformation, not a summarization step.
- Preserve complete finding descriptions from the raw artifact.
- Do not shorten, compress, or rewrite findings that already contain evidence.
- Do not replace detailed sections with partial sentences.
- If the raw artifact already matches the requested artifact type, preserve its content and only repair structure.
- Source identifiers are evidence references, not formatting.
- Every finding that has representative source identifiers in the raw artifact must include those identifiers in the normalized artifact.
- Do not replace cited findings with summaries that remove their supporting source identifiers.
- If a finding cannot retain its evidence references, preserve the original finding text rather than summarizing it.
- Never remove evidence references during normalization.
- Do not infer intent, motivation, audience response, prevalence, or broader applicability unless the raw artifact explicitly addresses it.
- When the raw artifact does not support a required section, write: "Not established by the raw artifact."
- Open Questions must arise directly from limitations or uncertainty already present in the raw artifact.
- Every required section must contain text, but placeholder text is preferable to unsupported speculation.
- Return only the normalized Markdown artifact.
"""

payload = {
    "model": model,
    "stream": False,
    "think": False,
    "options": {
        "num_ctx": 16384,
        "num_predict": 6144,
    },
    "messages": [
        {
            "role": "system",
            "content": (
                "You normalize Abbey Root research artifacts into a "
                "canonical Markdown structure. Use only the supplied "
                "artifact and do not invent information."
            ),
        },
        {
            "role": "user",
            "content": (
                instructions
                + "\n\n===== RAW RESEARCH ARTIFACT =====\n"
                + raw_content
            ),
        },
    ],
}

print("Abbey Research Normalization")
print()
print(f"Model:   {model}")
print(f"Ollama:  {ollama_url}")
print(f"Input:   {input_path}")
print(f"Output:  {output_path}")
print()
print("Normalizing research...")

request = urllib.request.Request(
    f"{ollama_url.rstrip('/')}/api/chat",
    data=json.dumps(payload).encode("utf-8"),
    headers={"Content-Type": "application/json"},
    method="POST",
)

started = time.monotonic()

try:
    with urllib.request.urlopen(request, timeout=1200) as response:
        response_data = json.loads(
            response.read().decode("utf-8")
        )
except urllib.error.HTTPError as exc:
    print(f"HTTP error: {exc.code}", file=sys.stderr)
    print(exc.read().decode("utf-8"), file=sys.stderr)
    sys.exit(1)
except Exception as exc:
    print(f"Ollama request failed: {exc}", file=sys.stderr)
    sys.exit(1)

runtime = time.monotonic() - started
content = response_data.get("message", {}).get("content", "")

if not content.strip():
    print("Ollama returned an empty response.", file=sys.stderr)
    sys.exit(1)

output_path.write_text(
    content.rstrip() + "\n",
    encoding="utf-8",
)

print()
print("Normalization complete.")
print(f"Runtime: {runtime:.1f} seconds")
print(f"Result: {output_path}")
PYTHON_NORMALIZE
}


sanitize_research() {
  local input_file=""
  local output_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --input)
        input_file="$2"
        shift 2
        ;;
      --output)
        output_file="$2"
        shift 2
        ;;
      -h|--help|help)
        usage
        exit 0
        ;;
      *)
        echo "Unknown option: $1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$input_file" || -z "$output_file" ]]; then
    echo "Usage: abbey research sanitize --input FILE --output FILE" >&2
    exit 1
  fi

  python3 - "$input_file" "$output_file" <<'PYTHON_SANITIZE'
import sys
import unicodedata
from pathlib import Path

input_path = Path(sys.argv[1])
output_path = Path(sys.argv[2])

content = input_path.read_text(encoding="utf-8")

content = unicodedata.normalize("NFKC", content)

replacements = {
    "\u2018": "'",
    "\u2019": "'",
    "\u201c": '"',
    "\u201d": '"',
    "\u2013": "-",
    "\u2014": "-",
    "\u2010": "-",
    "\u2011": "-",
    "\u00a0": " ",
}

for old, new in replacements.items():
    content = content.replace(old, new)

lines = []

for line in content.splitlines():
    if line.startswith("#"):
        line = line.rstrip()

    lines.append(line)

content = "\n".join(lines)

output_path.write_text(
    content.rstrip() + "\n",
    encoding="utf-8",
)

print("Sanitization complete.")
PYTHON_SANITIZE
}


validate_research() {
  local input_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --input)
        if [[ -z "${2:-}" ]]; then
          echo "Option --input requires a file." >&2
          exit 1
        fi

        input_file="$2"
        shift 2
        ;;

      -h|--help|help)
        usage
        exit 0
        ;;

      *)
        echo "Unknown option: $1" >&2
        echo >&2
        usage >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$input_file" ]]; then
    echo "Missing required option: --input" >&2
    exit 1
  fi

  if [[ ! -f "$input_file" ]]; then
    echo "Input file not found:" >&2
    echo "$input_file" >&2
    exit 1
  fi

  python3 - "$input_file" <<'PYTHON_VALIDATE'
import re
import sys
from pathlib import Path

input_path = Path(sys.argv[1])
content = input_path.read_text(encoding="utf-8")

required_sections = [
    "Summary",
    "Observations",
    "Evidence",
    "Conclusions",
    "Limitations",
    "Open Questions",
]

failures = []

title_matches = re.findall(
    r"^# Research Result\s*$",
    content,
    flags=re.MULTILINE,
)

if not title_matches:
    failures.append(
        "Missing required title: # Research Result"
    )
elif len(title_matches) > 1:
    failures.append(
        "Duplicate required title: # Research Result"
    )

heading_matches = list(
    re.finditer(
        r"^## (.+?)\s*$",
        content,
        flags=re.MULTILINE,
    )
)

heading_names = [
    match.group(1).strip()
    for match in heading_matches
]

for section in required_sections:
    count = heading_names.count(section)

    if count == 0:
        failures.append(
            f"Missing required section: ## {section}"
        )
    elif count > 1:
        failures.append(
            f"Duplicate required section: ## {section}"
        )

present_required = [
    name
    for name in heading_names
    if name in required_sections
]

if (
    len(present_required) == len(required_sections)
    and present_required != required_sections
):
    failures.append(
        "Required sections are not in canonical order."
    )

for index, match in enumerate(heading_matches):
    section = match.group(1).strip()

    if section not in required_sections:
        continue

    start = match.end()
    end = (
        heading_matches[index + 1].start()
        if index + 1 < len(heading_matches)
        else len(content)
    )

    if not content[start:end].strip():
        failures.append(
            f"Section is empty: ## {section}"
        )

print("========================================")
print(" Abbey Research Validation")
print("========================================")
print()
print(f"Input: {input_path}")
print()

if failures:
    print("Failures")
    print("--------")

    for failure in failures:
        print(f"FAIL {failure}")

    print()
    print("Result: FAIL")
    sys.exit(1)

print("Checks")
print("------")
print("OK   Required title is present")
print("OK   Required sections are present")
print("OK   Required sections are unique")
print("OK   Required sections are in canonical order")
print("OK   Required sections contain content")
print()
print("Result: PASS")
PYTHON_VALIDATE
}

validate_review() {
  local manifest_file=""
  local corpus_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --manifest)
        if [[ -z "${2:-}" ]]; then
          echo "Option --manifest requires a file." >&2
          exit 1
        fi
        manifest_file="$2"
        shift 2
        ;;
      --corpus)
        if [[ -z "${2:-}" ]]; then
          echo "Option --corpus requires a file." >&2
          exit 1
        fi
        corpus_file="$2"
        shift 2
        ;;
      -h|--help|help)
        usage
        exit 0
        ;;
      *)
        echo "Unknown option for validate-review: $1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$manifest_file" ]]; then
    echo "Missing required option: --manifest" >&2
    exit 1
  fi

  if [[ -z "$corpus_file" ]]; then
    echo "Missing required option: --corpus" >&2
    exit 1
  fi

  if [[ ! -f "$manifest_file" ]]; then
    echo "Review manifest not found:" >&2
    echo "$manifest_file" >&2
    exit 1
  fi

  if [[ ! -f "$corpus_file" ]]; then
    echo "Corpus not found:" >&2
    echo "$corpus_file" >&2
    exit 1
  fi

  python3 \
    "$ABBEY_ROOT/tools/research/validate_review_manifest.py" \
    --manifest "$manifest_file" \
    --corpus "$corpus_file"
}

validate_discovery() {
  local manifest_file=""
  local corpus_file=""
  local batch_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --manifest)
        if [[ -z "${2:-}" ]]; then
          echo "Option --manifest requires a file." >&2
          exit 1
        fi
        manifest_file="$2"
        shift 2
        ;;
      --corpus)
        if [[ -z "${2:-}" ]]; then
          echo "Option --corpus requires a file." >&2
          exit 1
        fi
        corpus_file="$2"
        shift 2
        ;;
      --batch)
        if [[ -z "${2:-}" ]]; then
          echo "Option --batch requires a file." >&2
          exit 1
        fi
        batch_file="$2"
        shift 2
        ;;
      -h|--help|help)
        usage
        exit 0
        ;;
      *)
        echo "Unknown option for validate-discovery: $1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$manifest_file" ]]; then
    echo "Missing required option: --manifest" >&2
    exit 1
  fi
  if [[ -z "$corpus_file" ]]; then
    echo "Missing required option: --corpus" >&2
    exit 1
  fi
  if [[ -z "$batch_file" ]]; then
    echo "Missing required option: --batch" >&2
    exit 1
  fi
  if [[ ! -f "$manifest_file" ]]; then
    echo "Discovery manifest not found:" >&2
    echo "$manifest_file" >&2
    exit 1
  fi
  if [[ ! -f "$corpus_file" ]]; then
    echo "Corpus not found:" >&2
    echo "$corpus_file" >&2
    exit 1
  fi
  if [[ ! -f "$batch_file" ]]; then
    echo "Batch not found:" >&2
    echo "$batch_file" >&2
    exit 1
  fi

  python3 \
    "$ABBEY_ROOT/tools/research/validate_discovery_manifest.py" \
    --manifest "$manifest_file" \
    --corpus "$corpus_file" \
    --batch "$batch_file"
}

discover_observations() {
  python3 \
    "$ABBEY_ROOT/tools/research/run_observation_discovery.py" \
    --runner "$ABBEY_ROOT/tools/bin/abbey-research" \
    "$@"
}


fact_lock_usage() {
  cat <<'HELP'
Abbey Research Fact Lock

Usage:
  abbey research fact-lock propose \
    --model MODEL \
    --suite FILE \
    --output FILE \
    [--max-tokens N] \
    [--force]

  abbey research fact-lock validate \
    --suite FILE \
    --proposal FILE \
    [--normalized-output FILE]

  abbey research fact-lock review \
    --suite FILE \
    --proposal FILE

  abbey research fact-lock review-init \
    --suite FILE \
    --proposal FILE \
    --output FILE

Commands:
  propose   Generate a human-review-required fact-lock proposal.
  validate  Validate and optionally normalize a proposal.
  review    Print a deterministic, read-only human-review summary.
  review-init
            Create a blank, hash-bound review manifest.

Proposal does not approve a fact lock. Human review and explicit approval
remain separate workflow boundaries.
HELP
}


propose_fact_lock() {
  local model=""
  local suite_file=""
  local output_file=""
  local max_tokens="16000"
  local force="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --model)
        if [[ -z "${2:-}" ]]; then
          echo "Option --model requires a model name." >&2
          exit 1
        fi
        model="$2"
        shift 2
        ;;

      --suite)
        if [[ -z "${2:-}" ]]; then
          echo "Option --suite requires a file." >&2
          exit 1
        fi
        suite_file="$2"
        shift 2
        ;;

      --output)
        if [[ -z "${2:-}" ]]; then
          echo "Option --output requires a file." >&2
          exit 1
        fi
        output_file="$2"
        shift 2
        ;;

      --max-tokens)
        if [[ ! "${2:-}" =~ ^[1-9][0-9]*$ ]]; then
          echo "Option --max-tokens requires a positive integer." >&2
          exit 1
        fi
        max_tokens="$2"
        shift 2
        ;;

      --force)
        force="true"
        shift
        ;;

      -h|--help|help)
        fact_lock_usage
        exit 0
        ;;

      *)
        echo "Unknown option for fact-lock propose: $1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$model" ]]; then
    echo "Missing required option: --model" >&2
    exit 1
  fi
  if [[ -z "$suite_file" ]]; then
    echo "Missing required option: --suite" >&2
    exit 1
  fi
  if [[ -z "$output_file" ]]; then
    echo "Missing required option: --output" >&2
    exit 1
  fi
  if [[ ! -f "$suite_file" ]]; then
    echo "Request suite not found:" >&2
    echo "$suite_file" >&2
    exit 1
  fi

  local prompt_file
  prompt_file="$ABBEY_ROOT/docs/research/voice-analysis/prompts/propose-voice-fact-lock.md"

  local -a run_args=(
    --model "$model"
    --prompt "$prompt_file"
    --input "$suite_file"
    --output "$output_file"
    --max-tokens "$max_tokens"
  )
  if [[ "$force" == "true" ]]; then
    run_args+=(--force)
  fi

  run_research "${run_args[@]}"

  echo
  echo "Human review required."
  echo "Validate the proposal before review:"
  echo "  abbey research fact-lock validate \\"
  echo "    --suite $suite_file \\"
  echo "    --proposal $output_file"
}


validate_fact_lock_proposal() {
  local suite_file=""
  local proposal_file=""
  local normalized_output=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --suite)
        if [[ -z "${2:-}" ]]; then
          echo "Option --suite requires a file." >&2
          exit 1
        fi
        suite_file="$2"
        shift 2
        ;;

      --proposal)
        if [[ -z "${2:-}" ]]; then
          echo "Option --proposal requires a file." >&2
          exit 1
        fi
        proposal_file="$2"
        shift 2
        ;;

      --normalized-output)
        if [[ -z "${2:-}" ]]; then
          echo "Option --normalized-output requires a file." >&2
          exit 1
        fi
        normalized_output="$2"
        shift 2
        ;;

      -h|--help|help)
        fact_lock_usage
        exit 0
        ;;

      *)
        echo "Unknown option for fact-lock validate: $1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$suite_file" ]]; then
    echo "Missing required option: --suite" >&2
    exit 1
  fi
  if [[ -z "$proposal_file" ]]; then
    echo "Missing required option: --proposal" >&2
    exit 1
  fi
  if [[ ! -f "$suite_file" ]]; then
    echo "Request suite not found:" >&2
    echo "$suite_file" >&2
    exit 1
  fi
  if [[ ! -f "$proposal_file" ]]; then
    echo "Fact-lock proposal not found:" >&2
    echo "$proposal_file" >&2
    exit 1
  fi
  if [[ -n "$normalized_output" && -e "$normalized_output" ]]; then
    echo "Normalized output already exists:" >&2
    echo "$normalized_output" >&2
    exit 1
  fi

  local -a validate_args=(
    --suite "$suite_file"
    --proposal "$proposal_file"
  )
  if [[ -n "$normalized_output" ]]; then
    mkdir -p "$(dirname "$normalized_output")"
    validate_args+=(--normalized-output "$normalized_output")
  fi

  python3 \
    "$ABBEY_ROOT/tools/research/validate_voice_fact_lock_proposal.py" \
    "${validate_args[@]}"

  echo
  echo "Validation does not approve this proposal."
  echo "Human review is still required."
}


review_fact_lock_proposal() {
  local suite_file=""
  local proposal_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --suite)
        if [[ -z "${2:-}" ]]; then
          echo "Option --suite requires a file." >&2
          exit 1
        fi
        suite_file="$2"
        shift 2
        ;;

      --proposal)
        if [[ -z "${2:-}" ]]; then
          echo "Option --proposal requires a file." >&2
          exit 1
        fi
        proposal_file="$2"
        shift 2
        ;;

      -h|--help|help)
        fact_lock_usage
        exit 0
        ;;

      *)
        echo "Unknown option for fact-lock review: $1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$suite_file" ]]; then
    echo "Missing required option: --suite" >&2
    exit 1
  fi
  if [[ -z "$proposal_file" ]]; then
    echo "Missing required option: --proposal" >&2
    exit 1
  fi
  if [[ ! -f "$suite_file" ]]; then
    echo "Request suite not found:" >&2
    echo "$suite_file" >&2
    exit 1
  fi
  if [[ ! -f "$proposal_file" ]]; then
    echo "Fact-lock proposal not found:" >&2
    echo "$proposal_file" >&2
    exit 1
  fi

  python3 \
    "$ABBEY_ROOT/tools/research/summarize_voice_fact_lock_review.py" \
    --suite "$suite_file" \
    --proposal "$proposal_file"
}


init_fact_lock_review() {
  local suite_file=""
  local proposal_file=""
  local output_file=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --suite)
        if [[ -z "${2:-}" ]]; then
          echo "Option --suite requires a file." >&2
          exit 1
        fi
        suite_file="$2"
        shift 2
        ;;

      --proposal)
        if [[ -z "${2:-}" ]]; then
          echo "Option --proposal requires a file." >&2
          exit 1
        fi
        proposal_file="$2"
        shift 2
        ;;

      --output)
        if [[ -z "${2:-}" ]]; then
          echo "Option --output requires a file." >&2
          exit 1
        fi
        output_file="$2"
        shift 2
        ;;

      -h|--help|help)
        fact_lock_usage
        exit 0
        ;;

      *)
        echo "Unknown option for fact-lock review-init: $1" >&2
        exit 1
        ;;
    esac
  done

  if [[ -z "$suite_file" ]]; then
    echo "Missing required option: --suite" >&2
    exit 1
  fi
  if [[ -z "$proposal_file" ]]; then
    echo "Missing required option: --proposal" >&2
    exit 1
  fi
  if [[ -z "$output_file" ]]; then
    echo "Missing required option: --output" >&2
    exit 1
  fi
  if [[ ! -f "$suite_file" ]]; then
    echo "Request suite not found:" >&2
    echo "$suite_file" >&2
    exit 1
  fi
  if [[ ! -f "$proposal_file" ]]; then
    echo "Fact-lock proposal not found:" >&2
    echo "$proposal_file" >&2
    exit 1
  fi

  python3 \
    "$ABBEY_ROOT/tools/research/init_voice_fact_lock_review.py" \
    --suite "$suite_file" \
    --proposal "$proposal_file" \
    --output "$output_file"
}


fact_lock_research() {
  local command="${1:-help}"

  case "$command" in
    propose)
      shift
      propose_fact_lock "$@"
      ;;

    validate)
      shift
      validate_fact_lock_proposal "$@"
      ;;

    review)
      shift
      review_fact_lock_proposal "$@"
      ;;

    review-init)
      shift
      init_fact_lock_review "$@"
      ;;

    help|-h|--help)
      fact_lock_usage
      ;;

    *)
      echo "Unknown fact-lock command: $command" >&2
      echo >&2
      fact_lock_usage >&2
      exit 1
      ;;
  esac
}


status_research() {
  if [[ $# -gt 0 ]]; then
    case "$1" in
      -h|--help|help)
        cat <<'HELP'
Abbey Research Status

Usage:
  abbey research status

Discover formal research artifacts and report their relationships,
chain completeness, and provenance references.

The command is deterministic and read-only.
HELP
        return 0
        ;;

      *)
        echo "Unknown option for research status: $1" >&2
        return 1
        ;;
    esac
  fi

  python3 "$ABBEY_ROOT/scripts/abbey_research_status.py" \
    --repo "$ABBEY_ROOT"
}


command="${1:-help}"

case "$command" in
  run)
    shift
    run_research "$@"
    ;;

  normalize)
    shift
    normalize_research "$@"
    ;;

  sanitize)
    shift
    sanitize_research "$@"
    ;;

  validate)
    shift
    validate_research "$@"
    ;;

  validate-review)
    shift
    validate_review "$@"
    ;;

  validate-discovery)
    shift
    validate_discovery "$@"
    ;;

  discover)
    shift
    discover_observations "$@"
    ;;

  fact-lock)
    shift
    fact_lock_research "$@"
    ;;

  status)
    shift
    status_research "$@"
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    echo "Unknown research command: $command" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac
