#!/bin/bash
#
# Abbey Root Tool: abbey-git-sync
#
# Purpose:
#   Pull the latest Abbey Root changes and show repository status.
#
# Usage:
#   abbey-git-sync
#   abbey-git-sync --help
#

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

BLUE='\033[1;34m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
cat <<EOF
abbey-git-sync

Pull the latest Abbey Root changes and show repository status.

Usage:
    abbey-git-sync

EOF
exit 0
fi

cd "$REPO_ROOT"

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE} Abbey Root Git Sync${NC}"
echo -e "${BLUE}========================================${NC}"
echo

git pull
echo
git status

echo
echo -e "${GREEN}✓ Git sync completed.${NC}"
