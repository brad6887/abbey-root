#!/bin/bash
#
# Abbey Root Tool: abbey-new-tool
#
# Purpose:
#   Create a new Abbey Root command-line tool from the standard template.
#
# Usage:
#   abbey-new-tool <tool-name>
#

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TOOLS_DIR="$REPO_ROOT/tools"
TEMPLATE_FILE="$TOOLS_DIR/templates/tool.sh"

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
cat <<EOF
abbey-new-tool

Create a new Abbey Root command-line tool from the standard template.

Usage:
    abbey-new-tool <tool-name>

Example:
    abbey-new-tool abbey-doctor

EOF
exit 0
fi

TOOL_NAME="$1"

if [[ -z "$TOOL_NAME" ]]; then
  echo "ERROR: Missing tool name"
  echo "Usage: abbey-new-tool <tool-name>"
  exit 1
fi

if [[ "$TOOL_NAME" != abbey-* ]]; then
  echo "ERROR: Tool name must start with 'abbey-'"
  exit 1
fi

TARGET_FILE="$TOOLS_DIR/$TOOL_NAME"

if [[ -e "$TARGET_FILE" ]]; then
  echo "ERROR: Tool already exists: $TARGET_FILE"
  exit 1
fi

if [[ ! -f "$TEMPLATE_FILE" ]]; then
  echo "ERROR: Missing template: $TEMPLATE_FILE"
  exit 1
fi

sed "s/<tool-name>/$TOOL_NAME/g" "$TEMPLATE_FILE" > "$TARGET_FILE"
chmod +x "$TARGET_FILE"

echo "Created: $TARGET_FILE"
echo
echo "Next steps:"
echo "  vi $TARGET_FILE"
echo "  abbey-help"
echo "  tools/generate-command-docs.sh"
