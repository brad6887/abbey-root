#!/bin/bash
#
# Abbey Root Tool: abbey-ansible-docs
#
# Purpose:
#   Generate Abbey Root documentation using Ansible.
#
# Usage:
#   abbey-ansible-docs
#

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT/ansible" || exit 1

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
cat <<EOF
abbey-ansible-docs

Generate Abbey Root documentation using Ansible.

Usage:
    abbey-ansible-docs

This command:

  • Runs the documentation playbook
  • Regenerates files in docs/generated/
  • Uses the Ansible inventory and host variables as source data

EOF
exit 0
fi

ansible-playbook playbooks/docs.yml
