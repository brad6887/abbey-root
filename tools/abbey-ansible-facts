#!/bin/bash
#
# Abbey Root Tool: abbey-ansible-facts
#
# Purpose:
#   Gather and display system facts for all managed hosts.
#
# Usage:
#   abbey-ansible-facts
#

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT/ansible" || exit 1

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
cat <<EOF
abbey-ansible-facts

Gather and display system facts for all managed hosts.

Usage:
    abbey-ansible-facts

This command:

  • Gathers Ansible facts from all managed hosts
  • Displays operating system information
  • Shows kernel version
  • Shows primary IP address
  • Displays memory and CPU information

EOF
exit 0
fi

ansible-playbook playbooks/facts.yml
