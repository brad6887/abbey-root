#!/bin/bash
#
# Abbey Root Tool: abbey-ansible-docker
#
# Purpose:
#   Run the Docker verification playbook.
#
# Usage:
#   abbey-ansible-docker
#

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT/ansible" || exit 1

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
cat <<EOF
abbey-ansible-docker

Run the Docker verification playbook.

Usage:
    abbey-ansible-docker

This command:

  • Verifies Docker is installed
  • Checks the Docker service
  • Displays the Docker version
  • Lists running containers on Docker hosts

EOF
exit 0
fi

ansible-playbook playbooks/docker.yml
