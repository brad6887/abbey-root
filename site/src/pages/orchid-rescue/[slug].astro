---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const plants = await getCollection("plants");

  const orchids = plants.filter(
    (plant) => plant.data.type === "orchid"
  );

  return orchids.map((plant) => ({
    params: {
      slug: plant.id.replace(/\.md$/, ""),
    },
    props: {
      plant,
    },
  }));
}

const { plant } = Astro.props;
const { Content } = await render(plant);
---

<Layout
  title={`${plant.data.title} | Orchid Rescue`}
  description={plant.data.description}
>
  <main class="page">
    <p><a href="/orchid-rescue/">← Orchid Rescue</a></p>

    <h1>{plant.data.title}</h1>

    {plant.data.heroImage && (
      <img
        class="hero-image"
        src={plant.data.heroImage}
        alt={`${plant.data.title} at the beginning of the rescue`}
      />
    )}

    <dl>
      <dt>Status</dt>
      <dd>{plant.data.status}</dd>

      {plant.data.species && (
        <>
          <dt>Species</dt>
          <dd>{plant.data.species}</dd>
        </>
      )}

      {plant.data.acquired && (
        <>
          <dt>Acquired</dt>
          <dd>{plant.data.acquired.toLocaleDateString()}</dd>
        </>
      )}
    </dl>

    <article class="plant-content">
      <Content />
    </article>

    {plant.data.currentImage && (
      <section class="current-status">
        <h2>Current Condition</h2>

        <img
          src={plant.data.currentImage}
          alt={`${plant.data.title} in its current condition`}
        />

        {plant.data.updatedDate && (
          <p>
            Last updated: {plant.data.updatedDate.toLocaleDateString()}
          </p>
        )}
      </section>
    )}
  </main>
</Layout>

<style>
  .page {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    line-height: 1.6;
  }

  .hero-image,
  .current-status img {
    display: block;
    width: 100%;
    max-height: 650px;
    margin: 1.5rem 0;
    border-radius: 0.75rem;
    object-fit: contain;
  }

  dt {
    font-weight: 700;
    margin-top: 1rem;
  }

  dd {
    margin: 0 0 0.75rem 0;
  }

  .plant-content {
    margin-top: 2rem;
  }

  .plant-content :global(img) {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: 650px;
    height: auto;
    margin: 1.5rem auto;
    border-radius: 0.75rem;
    object-fit: contain;
  }

  .current-status {
    margin-top: 3rem;
  }
</style>
